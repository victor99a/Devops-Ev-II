{
  "annotations": {
    "list": []
  },
  "description": "EP3 DevOps — Greeting Service Full-Stack Dashboard. Monitorea disponibilidad, tasa de errores, uso de CPU/Memoria, métricas JVM, cobertura de pruebas y tiempos de despliegue de backend y frontend.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Disponibilidad del Servicio",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "1": { "color": "green", "text": "UP" } }, "type": "value" },
            { "options": { "0": { "color": "red", "text": "DOWN" } }, "type": "value" },
            { "options": { "match": "null", "text": "N/A" }, "type": "special" }
          ],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showPercentChange": false,
        "textMode": "name",
        "wideLayout": false
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "up{job=~\"greeting-backend|greeting-frontend\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "title": "Estado del Servicio (UP/DOWN)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB308", "value": 0.001 },
              { "color": "red", "value": 0.05 }
